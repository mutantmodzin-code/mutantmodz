{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "mutantmodz.in" }],
      "destination": "https://www.mutantmodz.in/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "mutantmodz.vercel.app" }],
      "destination": "https://www.mutantmodz.in/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "mutantmodz-m2gl.vercel.app" }],
      "destination": "https://www.mutantmodz.in/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ]
    }
  ]
}
